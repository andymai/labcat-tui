{
  "name": "@labcat/tui-shiki",
  "version": "0.6.0-beta.0",
  "description": "Syntax-highlighted code blocks for @labcat/tui, powered by Shiki",
  "license": "MIT",
  "type": "module",
  "sideEffects": ["./dist/index.js"],
  "files": ["dist", "README.md"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "size": "size-limit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@labcat/tui": "workspace:^",
    "@lit/react": "^1.0.7",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@lit/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "lit": "^3.2.1",
    "shiki": "^1.26.1"
  },
  "devDependencies": {
    "@labcat/tui": "workspace:^",
    "@lit/react": "^1.0.7",
    "@open-wc/testing-helpers": "^3.0.1",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@types/react": "^19.0.2",
    "@vitest/browser": "^3.0.0",
    "playwright": "^1.49.1",
    "react": "^19.0.0",
    "size-limit": "^11.1.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "size-limit": [
    {
      "name": "@labcat/tui-shiki entry (synchronous, ESM, brotli)",
      "path": "dist/index.js",
      "limit": "10 kB",
      "import": "*",
      "brotli": true,
      "ignore": ["shiki", "shiki/core", "shiki/engine/oniguruma", "shiki/wasm"]
    }
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
