{
  "name": "@labcat/tui-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Claude Code-styled TUI component library for the web",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "prepare": "husky",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "cem": "turbo run cem",
    "size": "turbo run size",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,css,md,mdx,yml,yaml}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.11",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.1",
    "size-limit": "^11.1.6",
    "turbo": "^2.9.14",
    "typescript": "^5.7.3"
  }
}
