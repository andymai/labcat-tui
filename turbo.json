{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "custom-elements.json"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "cem": {
      "outputs": ["custom-elements.json"]
    },
    "size": {
      "dependsOn": ["build"],
      "outputs": []
    }
  }
}
