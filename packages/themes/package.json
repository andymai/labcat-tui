{
  "name": "@labcat/tui-themes",
  "version": "0.6.0-beta.0",
  "description": "Additional theme presets for @labcat/tui",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "size": "size-limit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "4 kB",
      "gzip": true
    }
  ],
  "peerDependencies": {
    "@labcat/tui": "workspace:^"
  },
  "devDependencies": {
    "@labcat/tui": "workspace:^",
    "size-limit": "^12.1.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
