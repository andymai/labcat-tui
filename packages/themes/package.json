{
  "name": "@labcat/tui-themes",
  "version": "0.1.0",
  "description": "Additional theme presets for @labcat/tui",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": ["dist", "README.md"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "echo \"themes will get snapshot coverage in v0.5\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "size": "echo \"size budgets per-theme — wired up when first theme lands in v0.5\"",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@labcat/tui": "workspace:^"
  },
  "devDependencies": {
    "@labcat/tui": "workspace:^",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
