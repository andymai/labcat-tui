{
  "name": "@labcat/tui-react",
  "version": "0.6.0-beta.0",
  "description": "React wrappers for @labcat/tui",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "echo \"react tsd tests come in v0.5\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "size": "size-limit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@labcat/tui": "workspace:^",
    "react": ">=18"
  },
  "dependencies": {
    "@lit/react": "^1.0.7"
  },
  "devDependencies": {
    "@labcat/tui": "workspace:^",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "size-limit": "^12.1.0",
    "typescript": "^6.0.3"
  },
  "size-limit": [
    {
      "name": "@labcat/tui-react (ESM, gzip)",
      "path": "dist/index.js",
      "limit": "2 kB",
      "import": "*"
    }
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
